{
  "openapi": "3.0.3",
  "info": {
    "title": "Tree Education IOAS API",
    "version": "v1",
    "description": "与 tree-education-ioas-fronted main 对齐的正式接口契约。"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Auth"
        ],
        "summary": "用户名密码登录"
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Auth"
        ],
        "summary": "当前用户与权限开关"
      }
    },
    "/api/v1/operators/options": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Operator"
        ],
        "summary": "运营人员下拉"
      }
    },
    "/api/v1/operators": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Operator"
        ],
        "summary": "运营人员分页列表，支持 name 查询"
      }
    },
    "/api/v1/media/content/packages": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "ContentPackage"
        ],
        "summary": "主题包列表"
      },
      "post": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "ContentPackage"
        ],
        "summary": "新建主题包；仅接收 operatorId + topicName"
      }
    },
    "/api/v1/media/content/packages/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "ContentPackage"
        ],
        "summary": "主题包详情，files 按 script/video/image 分组"
      },
      "put": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "ContentPackage"
        ],
        "summary": "编辑 operatorId/topicName，并自动重算 fullPath"
      },
      "delete": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "ContentPackage"
        ],
        "summary": "逻辑删除主题包并将其下文件移入 7 天回收站"
      }
    },
    "/api/v1/media/content/packages/{id}/files": {
      "post": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "ContentPackage"
        ],
        "summary": "按 scripts/videos/images 分组批量上传素材"
      }
    },
    "/api/v1/media/assets": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "AssetFile"
        ],
        "summary": "素材列表"
      }
    },
    "/api/v1/media/assets/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "AssetFile"
        ],
        "summary": "单文件详情"
      },
      "delete": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "AssetFile"
        ],
        "summary": "删除单文件到回收站，刷新主题包计数和 uploadStatus"
      }
    },
    "/api/v1/media/assets/{id}/download": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "AssetFile"
        ],
        "summary": "下载文件"
      }
    },
    "/api/v1/media/assets/{id}/preview": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "AssetFile"
        ],
        "summary": "获取 previewUrl"
      }
    },
    "/api/v1/media/assets/recycle-bin": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "AssetRecycleBin"
        ],
        "summary": "文件回收站列表"
      }
    },
    "/api/v1/media/assets/recycle-bin/{id}/restore": {
      "post": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "AssetRecycleBin"
        ],
        "summary": "恢复单文件"
      }
    },
    "/api/v1/media/assets/recycle-bin/{id}/purge": {
      "delete": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "AssetRecycleBin"
        ],
        "summary": "永久删除单文件"
      }
    },
    "/api/v1/media/resources/tree": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "MediaResource"
        ],
        "summary": "运营人 -> 主题包 -> script/video/image 目录树"
      }
    },
    "/api/v1/media/resources/packages": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "MediaResource"
        ],
        "summary": "资源中心主题包卡片列表"
      }
    },
    "/api/v1/leads": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Lead"
        ],
        "summary": "线索列表"
      },
      "post": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Lead"
        ],
        "summary": "基于主题包创建线索，不强制 assetFileId"
      }
    },
    "/api/v1/leads/{id}": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Lead"
        ],
        "summary": "线索详情"
      },
      "patch": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Lead"
        ],
        "summary": "更新 remark/assignedTo/assignedToName/status"
      }
    },
    "/api/v1/leads/{id}/status": {
      "patch": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Lead"
        ],
        "summary": "更新线索状态"
      }
    },
    "/api/v1/tasks/media": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Task"
        ],
        "summary": "媒体任务列表，状态为 MediaTaskStatus"
      }
    },
    "/api/v1/tasks/operator": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Task"
        ],
        "summary": "运营任务列表，状态为 OperatorTaskStatus"
      }
    },
    "/api/v1/tasks/{id}": {
      "patch": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Task"
        ],
        "summary": "更新任务状态/进度/错误/负责人"
      }
    },
    "/api/v1/reports/media-output": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Report"
        ],
        "summary": "媒体报表 scriptTotal/videoTotal/imageTotal/weekPackageCount/monthPackageCount"
      }
    },
    "/api/v1/reports/operator-leads": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Report"
        ],
        "summary": "运营线索报表 leadTotal/todayNew/weekNew/unassigned/assigned/completed"
      }
    },
    "/api/v1/reports/operator/by-package": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Report"
        ],
        "summary": "线索按主题包统计"
      }
    },
    "/api/v1/reports/operator/trend": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Report"
        ],
        "summary": "线索趋势数据"
      }
    },
    "/api/v1/audit/logs": {
      "get": {
        "responses": {
          "200": {
            "description": "success"
          }
        },
        "tags": [
          "Audit"
        ],
        "summary": "审计日志列表"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "UserRole": {
        "type": "string",
        "enum": [
          "SUPER_ADMIN",
          "MEDIA",
          "OPERATOR",
          "CONSULTANT"
        ]
      },
      "ContentPackageStatus": {
        "type": "string",
        "enum": [
          "pending_upload",
          "uploading",
          "partial_completed",
          "completed",
          "deleted"
        ]
      },
      "UploadStatus": {
        "type": "string",
        "enum": [
          "uploading",
          "success",
          "failed",
          "partial_success",
          "pending_supplement"
        ]
      },
      "AssetFileType": {
        "type": "string",
        "enum": [
          "script",
          "video",
          "image"
        ]
      },
      "LeadStatus": {
        "type": "string",
        "enum": [
          "unassigned",
          "assigned",
          "following",
          "completed",
          "invalid"
        ]
      },
      "TaskType": {
        "type": "string",
        "enum": [
          "media_upload",
          "operator_lead_generate"
        ]
      },
      "TaskRoleType": {
        "type": "string",
        "enum": [
          "media",
          "operator"
        ]
      },
      "MediaTaskStatus": {
        "type": "string",
        "enum": [
          "uploading",
          "success",
          "failed",
          "partial_success",
          "pending_supplement"
        ]
      },
      "OperatorTaskStatus": {
        "type": "string",
        "enum": [
          "pending",
          "processing",
          "completed",
          "overdue",
          "rejected"
        ]
      }
    }
  }
}