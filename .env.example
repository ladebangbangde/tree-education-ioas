# =========================
# IOAS Backend
# =========================
IOAS_SERVER_PORT=8080
IOAS_HOST_PORT=18080

# =========================
# Database
# =========================
IOAS_DATASOURCE_URL=jdbc:mysql://host.docker.internal:3306/tree_education_ioas?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
IOAS_DATASOURCE_USERNAME=root
IOAS_DATASOURCE_PASSWORD=your_password

# =========================
# Redis
# =========================
IOAS_REDIS_HOST_PORT=6379

# =========================
# MinIO
# =========================
IOAS_MINIO_ACCESS_KEY=minioadmin
IOAS_MINIO_SECRET_KEY=minioadmin123
IOAS_MINIO_API_HOST_PORT=9000
IOAS_MINIO_CONSOLE_HOST_PORT=9001
IOAS_MINIO_HOST_DATA_DIR=./docker-data/minio
IOAS_STORAGE_BUCKET=ioas-assets
IOAS_STORAGE_PUBLIC_BASE_URL=http://localhost:9000/ioas-assets

# =========================
# JWT
# =========================
IOAS_JWT_SECRET=replace-with-your-own-jwt-secret
IOAS_JWT_EXPIRES_MINUTES=1440

# =========================
# WeCom
# =========================
IOAS_WECOM_ENABLED=false
IOAS_WECOM_CORP_ID=
IOAS_WECOM_AGENT_ID=
IOAS_WECOM_SECRET=
IOAS_WECOM_CALLBACK_TOKEN=
