# =========================
# IOAS Backend
# =========================
IOAS_SERVER_PORT=8080
IOAS_HOST_PORT=18080

# =========================
# Database
# Replace with your real production database connection.
# Do not commit real passwords to a public repository.
# =========================
IOAS_DATASOURCE_URL=jdbc:mysql://YOUR_DB_HOST:33306/tree_education_ioas?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC&useSSL=false&allowPublicKeyRetrieval=true
IOAS_DATASOURCE_USERNAME=root
IOAS_DATASOURCE_PASSWORD=CHANGE_ME

# =========================
# Redis
# =========================
IOAS_REDIS_HOST=YOUR_REDIS_HOST
IOAS_REDIS_PORT=16379

# =========================
# MinIO
# =========================
IOAS_MINIO_ACCESS_KEY=minioadmin
IOAS_MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
IOAS_MINIO_API_HOST_PORT=19000
IOAS_MINIO_CONSOLE_HOST_PORT=19001
IOAS_STORAGE_BUCKET=ioas-assets

# Backend internal MinIO endpoint. This is used inside docker-compose network only.
IOAS_MINIO_ENDPOINT=http://minio:9000

# Browser-facing HTTPS MinIO endpoint exposed by Alibaba Cloud Nginx + FRPS + FRPC.
IOAS_MINIO_PUBLIC_ENDPOINT=https://minioapi.ldbbd.com
IOAS_STORAGE_PUBLIC_BASE_URL=https://minioapi.ldbbd.com/ioas-assets

# MinIO public URLs.
MINIO_SERVER_URL=https://minioapi.ldbbd.com
MINIO_BROWSER_REDIRECT_URL=https://minioconsole.ldbbd.com

# =========================
# JWT
# Use a long random string in production.
# =========================
IOAS_JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
IOAS_JWT_EXPIRES_MINUTES=1440

# =========================
# Upload Task Limits
# =========================
IOAS_TASK_MAX_USER_RUNNING=3
IOAS_TASK_MAX_GLOBAL_RUNNING=20

# =========================
# Task Cleanup
# =========================
IOAS_TASK_CLEANUP_ENABLED=true
IOAS_TASK_CLEANUP_FIXED_DELAY_MS=300000
IOAS_TASK_INTERRUPTED_RETENTION_HOURS=24
IOAS_TASK_FAILED_RETENTION_DAYS=7
IOAS_TASK_CANCELLED_RETENTION_DAYS=7
IOAS_TASK_SUCCESS_LOG_RETENTION_DAYS=30

# =========================
# Spring Multipart
# =========================
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=5GB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=5GB

# =========================
# WeCom
# =========================
IOAS_WECOM_ENABLED=false
IOAS_WECOM_CORP_ID=
IOAS_WECOM_AGENT_ID=
IOAS_WECOM_SECRET=
IOAS_WECOM_CALLBACK_TOKEN=
